# Copy this file to `.env` and fill in your secrets.
# `.env` is git-ignored.

# Weights & Biases
WANDB_API_KEY=
WANDB_PROJECT=ag-news-classification
WANDB_ENTITY=

# MLflow (optional alternative)
MLFLOW_TRACKING_URI=./mlruns

# HuggingFace Hub (for pushing model checkpoints / Spaces)
HF_TOKEN=
HF_USERNAME=

# Random seed override (used by src.utils.repro)
GLOBAL_SEED=42
